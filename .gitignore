# Default-deny: ignore everything first.
*

# Allow directory traversal for re-includes.
!*/

# Root files to keep tracked.
!.gitignore
!AGENTS.md
!README.md
!REPORT.md
!Makefile
!main.py
!pyproject.toml
!.pre-commit-config.yaml

# Source and test trees.
!api/
!api/**
!application/
!application/**
!ingestion/
!ingestion/**
!infra/
!infra/**
!tests/
!tests/**

# Documentation and figures.
!docs/
!docs/**

# Explicitly ignore local-only runtime/build/cache artifacts.
.venv/
.vscode/
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
.ipynb_checkpoints/
*.pyc
*.egg-info/
lake/
plots/
exports/
.run/
lake_test/
.env
.env.*
docker/.env
